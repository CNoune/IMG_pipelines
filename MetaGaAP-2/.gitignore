# MetaGaAP 2 - version-control exclusions.

# --------------------------------------------------------------------------- #
# Python
# --------------------------------------------------------------------------- #
__pycache__/
*.py[cod]
*$py.class
*.egg
*.egg-info/
.eggs/
.installed.cfg
build/
dist/
sdist/
wheels/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# --------------------------------------------------------------------------- #
# Node / frontend
# --------------------------------------------------------------------------- #
node_modules/
frontend/dist/
frontend/node_modules/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Built UI bundled into the backend package (generated by `npm run build`)
backend/metagaap2/webui/

# --------------------------------------------------------------------------- #
# Pipeline data outputs (large / regenerable artefacts)
# --------------------------------------------------------------------------- #
*.bam
*.bam.bai
*.bai
*.sam
*.cram
*.crai
*.vcf
*.vcf.gz
*.vcf.gz.tbi
*.bcf
*.paf
*.fastq
*.fastq.gz
*.fq
*.fq.gz
*.fai
*.mmi
*.amb
*.ann
*.bwt
*.pac
*.sa

# --------------------------------------------------------------------------- #
# Editor / OS cruft
# --------------------------------------------------------------------------- #
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~
